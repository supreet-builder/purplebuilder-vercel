{
  "buildCommand": "cd purple-builder-app && npm install && npm run build",
  "outputDirectory": "purple-builder-app/dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/app/(.*)",
      "destination": "/app.html"
    },
    {
      "source": "/app",
      "destination": "/app.html"
    }
  ]
}
